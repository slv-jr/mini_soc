# ============================================================
# Mini-SOC — variables d'environnement de la stack Docker
# Copier en .env puis adapter :  cp .env.example .env
# Le playbook Ansible génère un .env avec des mots de passe aléatoires.
# NE JAMAIS committer le .env réel.
# ============================================================

# ── Topologie réseau (source unique — consommée par Docker ET l'app Python) ─────
# Sur PC Ubuntu l'interface est souvent eth0, enp3s0, ens33... (ip -br link)
SOC_IFACE=eth0
SOC_SUBNET=192.168.1.0/24
SOC_GATEWAY=192.168.1.1

# ── Sondes actives (cibles de disponibilité) ────────────────────────────────────
PROBE_DNS1=8.8.8.8
PROBE_DNS2=1.1.1.1

# ── Dashboard Mini-SOC : exposition & sécurité ──────────────────────────────────
# 0.0.0.0 requis pour la boucle de feedback Wazuh (host.docker.internal).
# DÉFINIR MINISOC_API_TOKEN dès que l'hôte est sur un LAN : il protège les
# endpoints POST (blocage d'IP, ingestion d'alertes). Ex: openssl rand -hex 24
DASHBOARD_HOST=0.0.0.0
DASHBOARD_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
MINISOC_API_TOKEN=

# ── InfluxDB ────────────────────────────────────────────────────────────────────
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change_me_influx
INFLUXDB_ORG=minisoc
INFLUXDB_BUCKET=network_metrics
INFLUXDB_TOKEN=change_me_super_secret_token

# ── Grafana ─────────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana

# ── Wazuh (profil: siem) ────────────────────────────────────────────────────────
# Mots de passe par défaut de la stack Wazuh single-node — À CHANGER.
# L'API exige majuscule + minuscule + chiffre + symbole (sinon erreur 5007).
WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=change_me_Wazuh_API_1.
INDEXER_USERNAME=admin
INDEXER_PASSWORD=change_me_Indexer_1
DASHBOARD_USERNAME=kibanaserver
DASHBOARD_PASSWORD=change_me_Dashboard_1
# Heap JVM de l'indexer OpenSearch — réduire à 512m sur machine 4 Go.
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g

# ── Redis ────────────────────────────────────────────────────────────────────────
REDIS_MAXMEMORY=256mb

# ── Threat intel (profil applicatif Python, lu via config) ──────────────────────
ABUSEIPDB_API_KEY=
OTX_API_KEY=

# ── Alerting ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
